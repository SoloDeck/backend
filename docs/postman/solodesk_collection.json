            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"deal_id\": \"{{deal_id}}\",\n  \"content\": {\n    \"project_overview\": \"Xay dung nen tang thuong mai dien tu day du tinh nang (da cap nhat).\",\n    \"scope_of_work\": [\"UI/UX\", \"Frontend\", \"Backend\", \"Thanh toan\", \"Trien khai\"],\n    \"deliverables\": [\"Ma nguon\", \"Tai lieu\", \"Ho tro 3 thang\"],\n    \"timeline\": \"10 tuan\",\n    \"pricing\": \"65,000,000 VND\",\n    \"payment_terms\": \"30% - 40% - 30%\",\n    \"assumptions\": \"Khach hang cung cap noi dung truoc ngay 7\"\n  }\n}" }
          }
