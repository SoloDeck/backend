{
  "info": {
    "name": "SoloDesk API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full API test collection for SoloDesk backend. Import solodesk_environment.json first, then run 1-Auth/Register and 1-Auth/Login to populate the token variable automatically."
  },
  "variable": [],
  "item": [

    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "if (d && d.access_token) pm.environment.set('token', d.access_token);",
            "if (d && d.user && d.user.id) pm.environment.set('user_id', d.user.id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@solodesk.vn\",\n  \"password\": \"Test@1234!\",\n  \"full_name\": \"Nguyen Van Test\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "if (d && d.access_token) pm.environment.set('token', d.access_token);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@solodesk.vn\",\n  \"password\": \"Test@1234!\"\n}" }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "if (d && d.access_token) pm.environment.set('admin_token', d.access_token);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@solodesk.vn\",\n  \"password\": \"Admin@1234!\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },

    {
      "name": "2 - Users",
      "item": [
        {
          "name": "Get Me",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "if (d && d.id) pm.environment.set('user_id', d.id);",
            "if (d && d.intake_share_token) pm.environment.set('intake_token', d.intake_share_token);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Nguyen Van A\",\n  \"skills\": [\"Web Development\", \"Mobile App\"],\n  \"hourly_rate\": 50,\n  \"currency\": \"USD\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me/password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"Test@1234!\",\n  \"new_password\": \"NewPass@5678!\"\n}" }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },

    {
      "name": "3 - Clients",
      "item": [
        {
          "name": "Create Client",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "if (d && d.id) pm.environment.set('client_id', d.id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/clients",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Cong ty ABC\",\n  \"email\": \"abc@company.vn\",\n  \"phone\": \"0901234567\",\n  \"type\": \"company\",\n  \"status\": \"prospect\",\n  \"address_city\": \"Ho Chi Minh\",\n  \"address_country\": \"Vietnam\",\n  \"notes\": \"Khach hang tiem nang\"\n}" }
          }
        },
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/clients?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["clients"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "status", "value": "prospect", "disabled": true },
                { "key": "name", "value": "ABC", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Client",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/clients/{{client_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/clients/{{client_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Cong ty ABC (Updated)\",\n  \"status\": \"active\",\n  \"notes\": \"Da ky hop dong\"\n}" }
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/clients/{{client_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Comm Log",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/clients/{{client_id}}/comm-logs",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"channel\": \"email\",\n  \"summary\": \"Da gui bao gia cho khach hang, cho phan hoi trong 3 ngay\",\n  \"communicated_at\": \"2026-06-30T09:00:00Z\"\n}" }
          }
        },
        {
          "name": "List Comm Logs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/clients/{{client_id}}/comm-logs",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },

    {
