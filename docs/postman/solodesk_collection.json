    {
      "name": "7 - Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/users?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "status", "value": "active", "disabled": true },
                { "key": "role", "value": "user", "disabled": true },
                { "key": "search", "value": "nguyen", "disabled": true },
                { "key": "sort_by", "value": "created_at", "disabled": true },
                { "key": "sort_order", "value": "desc", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
