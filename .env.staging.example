# ===========================================================================
# SoloDesk Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=staging
DEBUG=false
SECRET_KEY=CHANGE_ME_staging_32chars_random

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://solodesk:CHANGE_ME@staging-db:5432/solodesk
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://staging-redis:6379/0

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://staging-redis:6379/1
CELERY_RESULT_BACKEND=redis://staging-redis:6379/2

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_staging_jwt_32chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Google OAuth 2.0
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://staging-api.solodesk.space/api/v1/auth/google/callback

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_CHANGE_ME        # test key cho staging
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_PLAN_PRICE_ID=

# ---------------------------------------------------------------------------
# Object Storage (S3-compatible)
# ---------------------------------------------------------------------------
STORAGE_ENDPOINT=
STORAGE_BUCKET=solodesk-staging-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=ap-southeast-1

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@staging.solodesk.space
SMTP_FROM_NAME=SoloDesk
SMTP_TLS=false

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://staging.solodesk.space,http://localhost:5173