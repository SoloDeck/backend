# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=staging
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@staging-db-host:5432/solodesk
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://staging-redis-host:6379/0
CELERY_BROKER_URL=redis://staging-redis-host:6379/1
CELERY_RESULT_BACKEND=redis://staging-redis-host:6379/2

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=<generate: openssl rand -hex 32>
JWT_SECRET_KEY=<generate: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<staging Google OAuth client ID>
GOOGLE_CLIENT_SECRET=<staging Google OAuth client secret>
GOOGLE_REDIRECT_URI=https://staging.solodesk.space/api/v1/auth/google/callback

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<OpenAI API key>
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<Stripe test secret key for staging>
STRIPE_WEBHOOK_SECRET=<Stripe webhook secret for staging>
STRIPE_FREE_PLAN_PRICE_ID=<Stripe free plan price ID>

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
STORAGE_ENDPOINT=<S3-compatible endpoint URL>
STORAGE_BUCKET=solodesk-uploads-staging
STORAGE_ACCESS_KEY=<access key>
STORAGE_SECRET_KEY=<secret key>
STORAGE_REGION=ap-southeast-1

# ── Email (SMTP via SendGrid relay) ───────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=apikey
SMTP_PASSWORD=<SendGrid API key>
SMTP_FROM_EMAIL=noreply@solodesk.space
SMTP_FROM_NAME=SoloDesk

# ── Zalo OA ───────────────────────────────────────────────────────────────────
ZALO_OA_ACCESS_TOKEN=<Zalo OA access token>

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://staging.solodesk.space
