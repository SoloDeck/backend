# ===========================================================================
# SoloDesk Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-minimum-32-chars

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://solodesk:solodesk@localhost:5432/solodesk
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Google Services
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Legacy OAuth 2.0 credentials (pre-platform-split layout) — kept for rollback:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ---------------------------------------------------------------------------
# GROQ
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

# ---------------------------------------------------------------------------
# Groq (lead qualifier)
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_PLAN_PRICE_ID=

# ---------------------------------------------------------------------------
# MoMo (AIOv2 sandbox) — https://developers.momo.vn/v2/#/docs/aiov2
# Defaults (in src/config/settings.py) are MoMo's published sandbox
# test-merchant credentials; override here only if using a personal test merchant.
# ---------------------------------------------------------------------------
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=
MOMO_STORE_ID=
MOMO_ENDPOINT=
MOMO_REQUEST_TYPE=
MOMO_IPN_URL=
MOMO_REDIRECT_URL=

# ---------------------------------------------------------------------------
# Object Storage (S3-compatible)
# ---------------------------------------------------------------------------
STORAGE_ENDPOINT=
STORAGE_BUCKET=solodesk-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=ap-southeast-1

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@solodesk.app
SMTP_FROM_NAME=SoloDesk
SMTP_TLS=false

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Logging — behavior driven by APP_ENV (dev=console/DEBUG, staging+prod=json/INFO)
# ---------------------------------------------------------------------------
LOG_LEVEL=            # optional override: DEBUG|INFO|WARNING|ERROR|CRITICAL (prod clamps ≥INFO)
LOG_FORMAT=           # optional override: console|json
SERVICE_NAME=solodesk-api
LOG_REQUEST_BODY=false  # debug only, forced OFF in production